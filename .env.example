# GitHub Configuration
# Choose ONE authentication method:

# Method 1: GitHub App (Recommended for production)
# - Shows as 'app-name[bot]' in commits (e.g., terraform-remediation[bot])
# - Better security with granular permissions
# - Professional appearance
# - Setup: See docs/GITHUB_AUTHENTICATION.md
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
# OR

# Method 2: Personal Access Token (Easier for testing)
# - Shows as the token owner in commits (e.g., @terraform-bot)
# - Simpler setup
# - Use a dedicated bot account, NOT your personal account!
# - Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Required for both methods
GITHUB_WEBHOOK_SECRET=

# AI Provider (choose one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER=anthropic  # or openai
AI_MODEL=claude-3-5-sonnet-20241022  # or gpt-4

# Slack Configuration
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tf_ai_remediation

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
DRY_RUN=false

# Auto-Merge Settings
AUTO_MERGE_ENABLED=true
AUTO_MERGE_DELAY_HOURS=24
LOW_RISK_AUTO_MERGE=true
MEDIUM_RISK_AUTO_MERGE=false

# Risk Detection
MAX_FILES_CHANGED=2
MAX_LINES_PER_FILE=20
AI_CONFIDENCE_THRESHOLD=85

# GitHub Organizations to Monitor (comma-separated)
MONITORED_ORGS=org1,org2
# Optional: specific repos (format: org/repo,org/repo)
MONITORED_REPOS=

# Webhook Configuration
WEBHOOK_PORT=8000
WEBHOOK_HOST=0.0.0.0
